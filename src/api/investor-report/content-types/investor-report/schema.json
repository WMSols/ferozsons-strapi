{
  "kind": "collectionType",
  "collectionName": "investor_reports",
  "info": {
    "singularName": "investor-report",
    "pluralName": "investor-reports",
    "displayName": "Investor Report"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "year": {
      "type": "integer"
    },
    "quarter": {
      "type": "string"
    },
    "report_file": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "report_type": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::report-type.report-type"
    },
    "quarterNo": {
      "type": "enumeration",
      "required": true,
      "enum": [
        "q1",
        "q2",
        "q3",
        "q4"
      ]
    }
  }
}
