{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name"
    },
    "formulation": {
      "type": "string"
    },
    "concentration": {
      "type": "string"
    },
    "dosage": {
      "type": "string"
    },
    "commonlyPrescribed": {
      "type": "boolean"
    },
    "prescriptionRequired": {
      "type": "boolean"
    },
    "availableOnline": {
      "type": "boolean"
    },
    "description": {
      "type": "blocks"
    },
    "product_category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::product-category.product-category"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "dvagoUrl": {
      "type": "text",
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "availableOnline"
            },
            true
          ]
        }
      }
    },
    "faqFile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "instructionsFile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "pamphletFile": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
